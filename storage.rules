rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAdmin() {
      return request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /courses/thumbnails/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /courses/videos/{videoId} {
      allow read: if true; // In production, might restrict to enrolled users
      allow write: if isAdmin();
    }
    
    match /programs/thumbnails/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /workshops/thumbnails/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /blog/thumbnails/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/avatars/{userId}/{imageId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }
    
    match /certificates/{userId}/{certificateId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
